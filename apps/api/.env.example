# ==============================
# App
# ==============================
APP_NAME=AI Email Assistant
APP_ENV=development          # development | staging | production
DEBUG=true
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
SECRET_KEY=change_this_to_a_long_random_string

# ==============================
# Database (PostgreSQL)
# ==============================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_email_assistant
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_email_assistant

# ==============================
# Redis (Cache / Celery Broker / Context Store)
# ==============================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==============================
# Clerk (User Auth / Session Management)
# ==============================
# Clerk handles user sign-up/login/session — NOT Google OAuth login.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
CLERK_FRONTEND_API=your-app.clerk.accounts.dev

# ==============================
# Google OAuth (Gmail / Calendar / Meet data access ONLY — separate from Clerk login)
# ==============================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.modify,https://www.googleapis.com/auth/gmail.compose,https://www.googleapis.com/auth/calendar

# Gmail Pub/Sub push notifications
GOOGLE_PUBSUB_PROJECT_ID=your_gcp_project_id
GOOGLE_PUBSUB_TOPIC=gmail-notifications
GOOGLE_PUBSUB_SUBSCRIPTION=gmail-notifications-sub
GOOGLE_PUBSUB_VERIFICATION_TOKEN=change_this_webhook_verification_token

# Encryption key for storing Google (Gmail/Calendar) OAuth tokens at rest
TOKEN_ENCRYPTION_KEY=change_this_to_a_32_byte_key

# ==============================
# OpenAI (LLM + Embeddings)
# ==============================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL_PRIMARY=gpt-5.5
OPENAI_MODEL_CLASSIFIER=gpt-5.5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ==============================
# LangGraph / LangChain / LangSmith
# ==============================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=ai-email-assistant

# ==============================
# Qdrant (Vector DB)
# ==============================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_COMPANY_MEMORY=company_memory
QDRANT_COLLECTION_RESEARCH_CACHE=research_cache
QDRANT_COLLECTION_SUPPORT_KB=support_kb

# ==============================
# ElevenLabs (Voice STT/TTS)
# ==============================
ELEVENLABS_API_KEY=el_xxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=default_voice_id
ELEVENLABS_STT_MODEL=eleven-stt-v1
ELEVENLABS_TTS_MODEL=eleven-multilingual-v2

# ==============================
# Web Search / Market Research Agent
# ==============================
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxx
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxx
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxx
BRAVE_SEARCH_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ==============================
# OCR (Payment Agent - Invoice Extraction)
# ==============================
OCR_ENGINE=tesseract          # tesseract | google_vision | aws_textract
GOOGLE_VISION_API_KEY=
AWS_TEXTRACT_ACCESS_KEY=
AWS_TEXTRACT_SECRET_KEY=
AWS_REGION=us-east-1

# ==============================
# Payment Providers (Payment Agent - Future, disabled in MVP)
# ==============================
PAYMENTS_ENABLED=false
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx
BANK_API_BASE_URL=
BANK_API_KEY=

# Policy defaults
PAYMENT_AUTO_PREVIEW_THRESHOLD=500
PAYMENT_DUAL_APPROVAL_THRESHOLD=5000

# ==============================
# Monitoring / Observability
# ==============================
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2

# ==============================
# Feature Flags
# ==============================
FEATURE_VOICE_ENABLED=true
FEATURE_RESEARCH_AGENT_ENABLED=true
FEATURE_PAYMENT_AGENT_ENABLED=false
FEATURE_MULTI_ACCOUNT_ENABLED=false

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_GMAIL_PER_MIN=60
RATE_LIMIT_CALENDAR_PER_MIN=60
RATE_LIMIT_COMMAND_CENTER_PER_MIN=30

# ==============================
# CORS
# ==============================
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.yourdomain.com
